# Copy this file to .env and fill in your values.
# Real environment variables always take precedence over this file.

# --- SQS ---
SQS_QUEUE_URL=https://<your_sqs_url>
AWS_REGION=your_sqs_region
SQS_MAX_MESSAGES_PER_POLL=4
SQS_POLL_WAIT_TIME=20
SQS_VISIBILITY_TIMEOUT=60

# --- Sandbox ---
NSJAIL_PATH=nsjail_installation_path
NSJAIL_CONFIG_PATH=path_to_.cfg_file

# --- Execution ---
MAX_CONCURRENT=4
COMPILATION_TIMEOUT=30
DEFAULT_TIME_LIMIT=5
DEFAULT_MEMORY_LIMIT=128
MAX_OUTPUT_BYTES=262144
MAX_OUTPUT_LINES=5000
TEMP_DIR=/tmp/codinglemon
OUTPUT_DIR=/tmp/codinglemon/reports

# --- Redis (ElastiCache) ---
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_REPORT_TTL=300

# --- Log ---
LOG_LEVEL=INFO
LOG_DIR=/path/to/your/log/directory

# --- Worker ---
MAX_CONSECUTIVE_ERRORS=5
